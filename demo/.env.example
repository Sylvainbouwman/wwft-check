# Kopieer dit bestand naar .env en vul je eigen waarden in.
# Zonder KVK_API_KEY draait de app in demo-modus met voorbeelddata.

# KvK API sleutel (aanvragen via https://developers.kvk.nl)
KVK_API_KEY=

# KvK API base URL
# Test-omgeving : https://developers.kvk.nl/test/api/v2
# Productie     : https://api.kvk.nl/api/v2
KVK_BASE_URL=https://api.kvk.nl/api/v2

# OpenSanctions API key (gratis registreren op https://www.opensanctions.org/api/)
OPENSANCTIONS_API_KEY=
